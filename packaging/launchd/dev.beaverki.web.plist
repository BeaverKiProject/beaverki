<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>dev.beaverki.web</string>

  <key>ProgramArguments</key>
  <array>
    <string>__BEAVERKI_INSTALL_DIR__/bin/beaverki-web</string>
    <string>--config-dir</string>
    <string>__BEAVERKI_CONFIG_DIR__</string>
    <string>--listen-addr</string>
    <string>127.0.0.1:7676</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ProcessType</key>
  <string>Interactive</string>
</dict>
</plist>
